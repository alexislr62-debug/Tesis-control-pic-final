                    "encoding": "UTF-8"
                },
                {
                    "include": "../../../../../framework/usb/inc/usb_ch9.h",
                    "encoding": "UTF-8"
                },
                {
                    "include": "../../../../../framework/usb/inc/usb_common.h",
                    "encoding": "UTF-8"
                },
                {
                    "include": "../../../../../framework/usb/inc/usb_device.h",
                    "encoding": "UTF-8"
                },
                {
                    "include": "../../../../../framework/usb/inc/usb_device_cdc.h",
                    "encoding": "UTF-8"
                },
                {
                    "include": "../../../../../framework/usb/src/usb_device_local.h",
                    "encoding": "UTF-8"
                },
                {
                    "include": "../../../../../framework/usb/inc/usb_hal.h",
                    "encoding": "UTF-8"
                },
                {
                    "include": "../../../../../framework/usb/inc/usb_hal_pic18.h",
                    "encoding": "UTF-8"
                },
                {
                    "include": "../../../../../bsp/picdem_fs_usb/buttons.c",
                    "encoding": "UTF-8"
                },
                {
                    "include": "../../../../../bsp/picdem_fs_usb/leds.c",
                    "encoding": "UTF-8"
                },
                {
                    "include": "../../../../../framework/usb/src/usb_device.c",
                    "encoding": "UTF-8"
                },
                {
                    "include": "../../../../../framework/usb/src/usb_device_cdc.c",
                    "encoding": "UTF-8"
                },
                {
                    "include": "demo_src/*",
                    "encoding": "UTF-8"
                },
                {
                    "include": "picdem_fs_usb.x/*",
                    "encoding": "UTF-8"
                },
                "picdem_fs_usb.x/dist/PICDEM_FSUSB/production/picdem_fs_usb.x.production.hex",
                "picdem_fs_usb.x/dist/PICDEM_FSUSB/production/picdem_fs_usb.x.production.elf"
            ]
        }
    ]
}
