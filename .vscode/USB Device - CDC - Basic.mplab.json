{
    "version": "1.8",
    "importedFrom": "picdem_fs_usb.x",
    "configurations": [
        {
            "name": "PICDEM_FSUSB",
            "id": "conf1",
            "device": "PIC18F4550",
            "imageType": "application",
            "imagePath": "./out/USB Device - CDC - Basic/PICDEM_FSUSB.elf",
            "toolProperties": "PICDEM_FSUSB-tool",
            "packs": [
                {
                    "name": "PIC18Fxxxx_DFP",
                    "vendor": "Microchip",
                    "version": "1.1.19"
                }
            ],
            "fileSet": "Project files",
            "toolchain": "PICDEM_FSUSB-XC8"
        }
    ],
    "propertyGroups": [
        {
            "name": "PICDEM_FSUSB-XC8",
            "type": "toolchain",
            "provider": "microchip.toolchains:xc8@1.45",
            "properties": {
                "HI-TECH-COMP.additional-warnings": true,
                "HI-TECH-COMP.asmlist": true,
                "HI-TECH-COMP.call-prologues": false,
                "HI-TECH-COMP.default-bitfield-type": true,
                "HI-TECH-COMP.default-char-type": true,
                "HI-TECH-COMP.disable-optimizations": false,
                "HI-TECH-COMP.extra-include-directories": "demo_src;../../../../../framework/usb/inc;../../../../../bsp/picdem_fs_usb;picdem_fs_usb.x",
                "HI-TECH-COMP.favor-optimization-for": "+speed,-space",
                "HI-TECH-COMP.garbage-collect-data": true,
                "HI-TECH-COMP.garbage-collect-functions": true,
                "HI-TECH-COMP.identifier-length": "255",
                "HI-TECH-COMP.local-generation": false,
                "HI-TECH-COMP.operation-mode": "pro",
                "HI-TECH-COMP.opt-xc8-compiler-strict_ansi": false,
                "HI-TECH-COMP.optimization-assembler": true,
                "HI-TECH-COMP.optimization-assembler-files": false,
                "HI-TECH-COMP.optimization-debug": false,
                "HI-TECH-COMP.optimization-invariant-enable": false,
                "HI-TECH-COMP.optimization-invariant-value": "16",
                "HI-TECH-COMP.optimization-level": "-O3",
                "HI-TECH-COMP.optimization-speed": true,
                "HI-TECH-COMP.optimization-stable-enable": false,
                "HI-TECH-COMP.preprocess-assembler": false,
                "HI-TECH-COMP.short-enums": true,
                "HI-TECH-COMP.tentative-definitions": "-fno-common",
                "HI-TECH-COMP.use-cci": false,
                "HI-TECH-COMP.use-iar": false,
                "HI-TECH-COMP.verbose": false,
                "HI-TECH-COMP.warning-level": "0",
                "HI-TECH-COMP.what-to-do": "require",
                "HI-TECH-LINK.additional-options-extend-address": false,
                "HI-TECH-LINK.additional-options-use-response-files": false,
                "HI-TECH-LINK.backup-reset-condition-flags": false,
                "HI-TECH-LINK.calibrate-oscillator": true,
                "HI-TECH-LINK.clear-bss": true,
                "HI-TECH-LINK.code-model-external": "wordwrite",
                "HI-TECH-LINK.create-html-files": false,
                "HI-TECH-LINK.data-model-size-of-double": "32",
                "HI-TECH-LINK.data-model-size-of-double-gcc": "no-short-double",
                "HI-TECH-LINK.data-model-size-of-float": "32",
                "HI-TECH-LINK.data-model-size-of-float-gcc": "no-short-float",
                "HI-TECH-LINK.display-class-usage": false,
                "HI-TECH-LINK.display-hex-usage": false,
                "HI-TECH-LINK.display-overall-usage": true,
                "HI-TECH-LINK.display-psect-usage": false,
                "HI-TECH-LINK.extra-lib-directories": "picdem_fs_usb.x",
                "HI-TECH-LINK.fill-flash-options-how": "0",
                "HI-TECH-LINK.fill-flash-options-inc-const": "1",
                "HI-TECH-LINK.fill-flash-options-what": "0",
                "HI-TECH-LINK.format-hex-file-for-download": false,
                "HI-TECH-LINK.initialize-data": true,
                "HI-TECH-LINK.input-libraries": "m",
                "HI-TECH-LINK.keep-generated-startup.as": false,
                "HI-TECH-LINK.link-in-c-library": true,
                "HI-TECH-LINK.link-in-peripheral-library": false,
                "HI-TECH-LINK.managed-stack": false,
                "HI-TECH-LINK.opt-xc8-linker-file": false,
                "HI-TECH-LINK.opt-xc8-linker-link_startup": false,
                "HI-TECH-LINK.program-the-device-with-default-config-words": true,
                "HI-TECH-LINK.remove-unused-sections": true,
                "XC8-CO.stack-guidance": false,
                "XC8-config-global.advanced-elf": true,
                "XC8-config-global.constdata-progmem": false,
                "XC8-config-global.gcc-opt-driver-new": false,
                "XC8-config-global.gcc-opt-std": "--std=c89",
                "XC8-config-global.gcc-output-file-format": "dwarf-3",
                "XC8-config-global.mapped-progmem": false,
                "XC8-config-global.omit-pack-options": false,
                "XC8-config-global.omit-pack-options-new": "1",
                "XC8-config-global.output-file-format": "-mcof,+elf",
                "XC8-config-global.stack-size-high": "auto",
                "XC8-config-global.stack-size-low": "auto",
                "XC8-config-global.stack-size-main": "auto",
                "XC8-config-global.stack-type": "compiled",
                "XC8-config-global.wpo-lto": false
            }
        },
        {
            "name": "PICDEM_FSUSB-tool",
            "type": "tool",
            "properties": {
                "AutoSelectMemRanges": "auto",
                "Freeze Peripherals": true,
                "SecureSegment.SegmentProgramming": "FullChipProgramming",
                "ToolFirmwareFilePath": "Press to browse for a specific firmware version",
                "ToolFirmwareOption.UseLatestFirmware": true,
                "debugoptions.debug-startup": "Use system settings",
                "debugoptions.reset-behaviour": "Use system settings",
                "debugoptions.useswbreakpoints": false,
                "event.recorder.debugger.behavior": "Running",
                "event.recorder.enabled": false,
                "hwtoolclock.frcindebug": false,
                "memories.aux": false,
                "memories.bootflash": false,
                "memories.configurationmemory": true,
                "memories.configurationmemory2": true,
                "memories.dataflash": true,
                "memories.eeprom": true,
                "memories.flashdata": true,
                "memories.id": true,
                "memories.instruction.ram": true,
                "memories.instruction.ram.ranges": "${memories.instruction.ram.ranges}",
                "memories.programmemory": true,
                "memories.programmemory.ranges": "0-7fff",
                "poweroptions.powerenable": false,
                "programoptions.donoteraseauxmem": false,
                "programoptions.eraseb4program": true,
                "programoptions.preservedataflash": false,
                "programoptions.preserveeeprom": false,
                "programoptions.preserveeeprom.ranges": "0-ff",
                "programoptions.preserveprogramrange": false,
                "programoptions.preserveuserid": false,
                "programoptions.programcalmem": false,
                "programoptions.programuserotp": false,
                "programoptions.testmodeentrymethod": "VPPFirst",
                "programoptions.usehighvoltageonmclr": false,
                "programoptions.uselvpprogramming": false,
                "voltagevalue": "5.0"
            }
        }
    ],
    "fileSets": [
        {
            "name": "Project files",
            "files": [
                {
                    "include": "../../../../../bsp/picdem_fs_usb/buttons.h",
                    "encoding": "UTF-8"
                },
                {
                    "include": "../../../../../bsp/picdem_fs_usb/leds.h",
                    "encoding": "UTF-8"
                },
                {
